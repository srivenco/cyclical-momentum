# Copy this file to .env for local development
# NEVER commit .env to git

# Generate the hash by running:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
APP_PASSWORD_HASH=$2b$12$gxd/NdirS3Ufwm.R2kQFqe1Z53Me7UVCg1hnXUuf3hYHO4r/NSaXa

# Any random 32+ character string
JWT_SECRET=change-me-to-a-random-32-char-string

# Your GitHub Pages URL (no trailing slash)
# e.g. https://yourusername.github.io or https://yourusername.github.io/cyclical-momentum
ALLOWED_ORIGIN=http://localhost:5173
